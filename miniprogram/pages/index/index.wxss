/* pages/index/index.wxss */
.container {
  padding: 16px;
  padding-bottom: 32px;
}

.overview-bar {
  display: flex;
  justify-content: space-around;
  padding: 16px 0;
  margin-bottom: 12px;
  background: #fff;
  border-radius: 12px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.05);
}

.overview-item {
  text-align: center;
  padding: 8px 16px;
}

.overview-num {
  display: block;
  font-size: 28px;
  font-weight: 700;
  color: var(--primary);
}

.overview-label {
  font-size: 13px;
  color: var(--text-secondary);
  margin-top: 4px;
}

.filter-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
  margin-top: 12px;
}

.filter-group {
  display: flex;
  gap: 8px;
}

.filter-item {
  padding: 6px 14px;
  border-radius: 16px;
  font-size: 13px;
  background: #f0f0f0;
  color: var(--text-secondary);
}

.filter-item.active {
  background: var(--primary);
  color: white;
}

.year-picker {
  font-size: 13px;
  color: var(--text-secondary);
  padding: 6px 10px;
  background: #f0f0f0;
  border-radius: 16px;
}

.paper-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.paper-card {
  background: var(--card-bg);
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.05);
}

.paper-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.paper-year {
  font-size: 18px;
  font-weight: 600;
}

.paper-progress {
  display: flex;
  align-items: center;
  gap: 12px;
}

.progress-bar {
  flex: 1;
  height: 6px;
  background: #f0f0f0;
  border-radius: 3px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--primary);
  border-radius: 3px;
  transition: width 0.3s;
}

.progress-text {
  font-size: 12px;
  color: var(--text-secondary);
  min-width: 60px;
  text-align: right;
}
