.container {
  padding: 20rpx;
  background: #f8f9fa;
  min-height: 100vh;
}

/* 头部 */
.grammar-header {
  padding: 40rpx 20rpx;
  text-align: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}
.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}
.header-subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 10rpx;
}

/* 阶段列表 */
.stage-list {
  margin-bottom: 30rpx;
}
.stage-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.stage-info {
  flex: 1;
}
.stage-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}
.stage-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}
.stage-progress {
  display: flex;
  align-items: center;
}
.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #e8e8e8;
  border-radius: 6rpx;
  overflow: hidden;
  margin-right: 16rpx;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #52c41a, #73d13d);
  border-radius: 6rpx;
  transition: width 0.3s;
}
.progress-text {
  font-size: 24rpx;
  color: #999;
}
.stage-arrow {
  font-size: 36rpx;
  color: #ccc;
  margin-left: 20rpx;
}

/* 推荐按钮 */
.recommend-btn {
  padding: 30rpx;
  background: linear-gradient(135deg, #faad14, #ffc53d);
  border-radius: 16rpx;
  text-align: center;
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 40rpx;
}

/* 阶段头部 */
.stage-header, .point-header, .result-header {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}
.back-btn {
  font-size: 30rpx;
  color: #2c8cf0;
  margin-right: 20rpx;
}
.stage-title, .point-title, .result-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

/* 知识点列表 */
.point-list {
  margin-bottom: 30rpx;
}
.point-card {
  display: flex;
  align-items: center;
  padding: 28rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.point-status {
  margin-right: 20rpx;
}
.status-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #e8e8e8;
  border: 2rpx solid #ccc;
}
.status-dot.done {
  background: #52c41a;
  border-color: #52c41a;
}
.point-info {
  flex: 1;
}
.point-name {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 6rpx;
}
.point-count {
  font-size: 24rpx;
  color: #999;
}
.point-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 规则与例句 */
.rules-section, .examples-section {
  background: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #2c8cf0;
}
.rule-item {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
  margin-bottom: 12rpx;
  padding: 12rpx;
  background: #f8f9fa;
  border-radius: 8rpx;
}
.example-item {
  font-size: 28rpx;
  color: #444;
  line-height: 1.6;
  margin-bottom: 10rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 练习题 */
.question-section {
  background: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}
.question-progress {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
  text-align: right;
}
.question-card {
  margin-bottom: 20rpx;
}
.question-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

/* 选项 */
.options-list {
  margin-bottom: 20rpx;
}
.option-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  margin-bottom: 16rpx;
  background: #f8f9fa;
  border-radius: 10rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
.option-item:active {
  background: #e6f7ff;
  border-color: #2c8cf0;
}
.option-item.correct {
  background: #f6ffed;
  border-color: #52c41a;
}
.option-item.wrong {
  background: #fff2f0;
  border-color: #f5222d;
}
.option-item.right-answer {
  background: #f6ffed;
  border-color: #52c41a;
}
.option-key {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #2c8cf0;
  color: #fff;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-weight: bold;
}
.option-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

/* 排序题 */
.reorder-answer {
  min-height: 80rpx;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 10rpx;
  border: 2rpx dashed #ccc;
  margin-bottom: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.reorder-placeholder {
  color: #999;
  font-size: 26rpx;
}
.reorder-words {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.reorder-word {
  padding: 12rpx 20rpx;
  background: #e6f7ff;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #2c8cf0;
  border: 1rpx solid #91d5ff;
}
.reorder-actions {
  margin-bottom: 16rpx;
}
.undo-btn {
  font-size: 26rpx;
  color: #2c8cf0;
  padding: 8rpx 16rpx;
}

/* 解析 */
.explanation {
  padding: 20rpx;
  background: #fffbe6;
  border-radius: 10rpx;
  border-left: 4rpx solid #faad14;
  margin-top: 20rpx;
}
.ex-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #d48806;
  margin-bottom: 10rpx;
}
.ex-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 10rpx;
}
.ex-answer {
  font-size: 28rpx;
  color: #52c41a;
  font-weight: bold;
}

/* 按钮 */
.next-btn {
  background: #2c8cf0;
  color: #fff;
  border-radius: 10rpx;
  margin-top: 20rpx;
}

/* 结果页面 */
.result-score-card {
  padding: 60rpx;
  background: #fff;
  border-radius: 16rpx;
  text-align: center;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.score-value {
  font-size: 80rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}
.score-value.pass {
  color: #52c41a;
}
.score-value.fail {
  color: #f5222d;
}
.score-detail {
  font-size: 28rpx;
  color: #666;
}

.result-details {
  background: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}
.details-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}
.detail-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.detail-question {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
}
.detail-user {
  font-size: 26rpx;
  color: #f5222d;
  margin-bottom: 6rpx;
}
.detail-correct {
  font-size: 26rpx;
  color: #52c41a;
  margin-bottom: 6rpx;
}
.detail-explanation {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.weak-points {
  background: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}
.weak-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #f5222d;
  margin-bottom: 16rpx;
}
.weak-item {
  font-size: 28rpx;
  color: #555;
  padding: 8rpx 0;
}

.result-actions {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
}
.retry-btn, .back-list-btn {
  flex: 1;
  border-radius: 10rpx;
}
.retry-btn {
  background: #2c8cf0;
  color: #fff;
}
.back-list-btn {
  background: #f0f0f0;
  color: #666;
}
