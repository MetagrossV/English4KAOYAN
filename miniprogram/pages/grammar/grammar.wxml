<view class="container">
  <!-- 首页 -->
  <block wx:if="{{viewMode === 'home'}}">
    <view class="grammar-header">
      <view class="header-title">语法训练</view>
      <view class="header-subtitle">自适应学习 · 智能诊断 · 精准提升</view>
    </view>
    
    <!-- 能力概览卡 -->
    <view class="ability-card">
      <view class="ability-left">
        <view class="ability-score" style="color: {{ability.color}}">{{ability.score}}</view>
        <view class="ability-label">语法能力分</view>
      </view>
      <view class="ability-right">
        <view class="ability-level" style="background: {{ability.color}}">{{ability.level}}</view>
        <view class="ability-progress">已掌握 {{masteredCount}}/{{totalCount}} 个知识点</view>
      </view>
    </view>
    
    <!-- 雷达图 -->
    <view class="radar-card" wx:if="{{radarData.length > 0}}">
      <view class="radar-title">能力分布</view>
      <view class="radar-chart">
        <view wx:for="{{radarData}}" wx:key="name" class="radar-item">
          <view class="radar-name">{{item.name}}</view>
          <view class="radar-bar">
            <view class="radar-fill" style="width: {{item.value}}%; background: {{item.value >= 75 ? '#52c41a' : item.value >= 50 ? '#2c8cf0' : item.value >= 25 ? '#faad14' : '#f5222d'}}"></view>
          </view>
          <view class="radar-value">{{item.value}}</view>
        </view>
      </view>
    </view>
    
    <!-- 知识点状态预览 -->
    <view class="topics-preview">
      <view class="preview-header">
        <text>知识点掌握度</text>
        <text class="view-all" bindtap="onViewTopics">查看全部 →</text>
      </view>
      <view class="topic-grid">
        <view wx:for="{{topicStatuses}}" wx:key="id" class="topic-pill {{item.status}}">
          <text>{{item.name}}</text>
          <text class="topic-pct">{{item.probability}}%</text>
        </view>
      </view>
    </view>
    
    <!-- 开始训练按钮 -->
    <view class="start-section">
      <button class="btn-start" bindtap="onStartTraining">开始自适应训练</button>
      <view class="start-hint">系统将根据你的掌握程度智能出题</view>
    </view>
    
    <view class="reset-section">
      <text class="reset-link" bindtap="onResetProgress">重置学习进度</text>
    </view>
  </block>

  <!-- 训练页 -->
  <block wx:if="{{viewMode === 'training'}}">
    <view class="train-header">
      <text class="back-btn" bindtap="onBack">← 退出</text>
      <text class="train-progress">第 {{questionNumber}} 题</text>
    </view>
    
    <view class="question-card" wx:if="{{currentQuestion}}">
      <view class="question-tag">
        <text class="tag-topic">{{grammarTopics.topics[0].name}}</text>
        <text class="tag-difficulty {{currentQuestion.difficulty >= 3 ? 'hard' : currentQuestion.difficulty >= 2 ? 'medium' : 'easy'}}">
          {{currentQuestion.difficulty === 1 ? '简单' : currentQuestion.difficulty === 2 ? '中等' : currentQuestion.difficulty === 3 ? '困难' : '高阶'}}
        </text>
      </view>
      
      <view class="question-text">{{currentQuestion.question}}</view>
      
      <view class="options-list">
        <view wx:for="{{currentQuestion.options}}" wx:for-item="opt" wx:for-index="key" wx:key="key"
          class="option-item {{showExplanation ? (key === currentQuestion.answer ? 'correct' : (key === selectedAnswer ? 'wrong' : '')) : ''}}"
          bindtap="{{!showExplanation ? 'onSelectAnswer' : ''}}"
          data-answer="{{key}}">
          <text class="option-key">{{key}}</text>
          <text class="option-text">{{opt}}</text>
        </view>
      </view>
      
      <!-- 解析 -->
      <view class="explanation" wx:if="{{showExplanation}}">
        <view class="ex-result {{isCorrect ? 'ex-correct' : 'ex-wrong'}}">
          {{isCorrect ? '✓ 回答正确' : '✗ 回答错误'}}
        </view>
        <view class="ex-text">{{currentQuestion.explanation}}</view>
        <view class="ex-answer">正确答案：{{currentQuestion.answer}}</view>
      </view>
      
      <button class="btn-next" wx:if="{{showExplanation}}" bindtap="onNextQuestion">
        下一题
      </button>
    </view>
  </block>

  <!-- 结果页 -->
  <block wx:if="{{viewMode === 'result'}}">
    <view class="result-header">
      <text class="back-btn" bindtap="onBackHome">← 返回</text>
      <text class="result-title">训练报告</text>
    </view>
    
    <!-- 能力变化 -->
    <view class="result-ability">
      <view class="result-score" style="color: {{ability.color}}">{{ability.score}}</view>
      <view class="result-level">{{ability.level}}</view>
      <view class="result-count">本次训练 {{sessionLog.length}} 题</view>
    </view>
    
    <!-- 答题统计 -->
    <view class="session-stats" wx:if="{{sessionLog.length > 0}}">
      <view class="stat-row">
        <text class="stat-label">正确</text>
        <text class="stat-value correct">{{sessionLog.filter(item => item.isCorrect).length}}</text>
      </view>
      <view class="stat-row">
        <text class="stat-label">错误</text>
        <text class="stat-value wrong">{{sessionLog.filter(item => !item.isCorrect).length}}</text>
      </view>
      <view class="stat-row">
        <text class="stat-label">正确率</text>
        <text class="stat-value">{{Math.round(sessionLog.filter(item => item.isCorrect).length / sessionLog.length * 100)}}%</text>
      </view>
    </view>
    
    <!-- 诊断建议 -->
    <view class="diagnosis-card" wx:if="{{diagnosis}}">
      <view class="diag-title">诊断建议</view>
      <view wx:for="{{diagnosis.suggestions}}" wx:key="*this" class="diag-item">{{item}}</view>
    </view>
    
    <!-- 薄弱点 -->
    <view class="weak-card" wx:if="{{diagnosis && diagnosis.weakPoints.length > 0}}">
      <view class="weak-title">优先补强</view>
      <view wx:for="{{diagnosis.weakPoints}}" wx:key="id" class="weak-item">
        <text>{{item.name}}</text>
        <text class="weak-pct">{{Math.round(item.probability * 100)}}%</text>
      </view>
    </view>
    
    <!-- 推荐学习 -->
    <view class="recommend-card" wx:if="{{diagnosis && diagnosis.recommended.length > 0}}">
      <view class="rec-title">推荐学习</view>
      <view wx:for="{{diagnosis.recommended}}" wx:key="id" class="rec-item">
        <text>{{item.name}}</text>
        <text class="rec-pct">{{Math.round(item.probability * 100)}}%</text>
      </view>
    </view>
    
    <!-- 本次答题记录 -->
    <view class="log-card" wx:if="{{sessionLog.length > 0}}">
      <view class="log-title">答题记录</view>
      <view wx:for="{{sessionLog}}" wx:key="index" class="log-item">
        <text class="log-status {{item.isCorrect ? 'log-correct' : 'log-wrong'}}">{{item.isCorrect ? '✓' : '✗'}}</text>
        <text class="log-topic">{{item.topic}}</text>
        <text class="log-diff {{item.difficulty >= 3 ? 'diff-hard' : item.difficulty >= 2 ? 'diff-medium' : 'diff-easy'}}">
          {{item.difficulty === 1 ? '简' : item.difficulty === 2 ? '中' : item.difficulty === 3 ? '难' : '高'}}
        </text>
      </view>
    </view>
    
    <view class="result-actions">
      <button class="btn-start" bindtap="onStartTraining">继续训练</button>
      <button class="btn-home" bindtap="onBackHome">返回首页</button>
    </view>
  </block>

  <!-- 知识点列表页 -->
  <block wx:if="{{viewMode === 'topics'}}">
    <view class="topics-header">
      <text class="back-btn" bindtap="onBack">← 返回</text>
      <text class="topics-title">知识点详情</text>
    </view>
    
    <view class="topics-list">
      <view wx:for="{{topicStatuses}}" wx:key="id" class="topic-detail-card {{item.status}}">
        <view class="topic-detail-left">
          <view class="topic-detail-name">{{item.name}}</view>
          <view class="topic-detail-desc">{{item.description}}</view>
        </view>
        <view class="topic-detail-right">
          <view class="topic-detail-bar">
            <view class="topic-detail-fill" style="width: {{item.probability}}%; background: {{item.probability >= 85 ? '#52c41a' : item.probability >= 50 ? '#2c8cf0' : item.probability >= 25 ? '#faad14' : '#f5222d'}}"></view>
          </view>
          <view class="topic-detail-pct">{{item.probability}}%</view>
          <view class="topic-detail-status">{{item.status === 'mastered' ? '已掌握' : item.status === 'weak' ? '薄弱' : item.status === 'learning' ? '学习中' : '未开始'}}</view>
        </view>
      </view>
    </view>
  </block>
</view>