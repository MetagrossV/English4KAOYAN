/**app.wxss**/
page {
  --primary: #4a7c59;
  --primary-light: #e8f5e9;
  --accent: #f5a623;
  --bg: #faf8f5;
  --card-bg: #ffffff;
  --text: #2c3e50;
  --text-secondary: #7f8c8d;
  --border: #e8e8e8;
  --mark-q1: #ffebee;
  --mark-q2: #fff8e1;
  --mark-q3: #e8f5e9;
  --mark-q4: #e3f2fd;
  --mark-q5: #f3e5f5;
  --color-q1: #e57373;
  --color-q2: #ffb74d;
  --color-q3: #81c784;
  --color-q4: #64b5f6;
  --color-q5: #ba68c8;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background-color: var(--bg);
  color: var(--text);
  font-size: 16px;
  line-height: 1.6;
}

.container {
  padding: 16px;
  max-width: 100%;
}

.card {
  background: var(--card-bg);
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.05);
}

.btn-primary {
  background: var(--primary);
  color: white;
  border-radius: 24px;
  padding: 12px 24px;
  font-size: 15px;
  font-weight: 500;
  border: none;
  text-align: center;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-ghost {
  background: transparent;
  color: var(--primary);
  border: 1px solid var(--primary);
  border-radius: 24px;
  padding: 12px 24px;
  font-size: 15px;
}

.tag {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 12px;
  margin-right: 6px;
}

.tag-english1 {
  background: #e3f2fd;
  color: #1976d2;
}

.tag-english2 {
  background: #fce4ec;
  color: #c2185b;
}

.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
